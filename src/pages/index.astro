---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroTraining from '../assets/hafiz-latiff-training.jpg';
import enterprisePublishing from '../assets/hafiz-latiff-bengkel.jpg';
import {
	MODULES,
	METHODOLOGY,
	TRUSTED_BY,
	CASE_STUDIES,
	PROGRAM_OPTIONS,
	PAX_OPTIONS,
	SITE_DESCRIPTION,
} from '../consts';
import copy from '../content/data/pages/home.json';

const moduleEntries = Object.entries(MODULES);
const legacyServices = copy.legacy.services;

const ICON_PATHS: Record<string, string> = {
	pen: '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/>',
	layout: '<rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/>',
	visual: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>',
	print: '<path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>',
};
---

<BaseLayout title={copy.metaTitle} description={SITE_DESCRIPTION}>
	{/* ---------- 1. HERO ---------- */}
	<section class="hero section-paper">
		<div class="container hero-grid">
			<div class="hero-copy">
				<p class="eyebrow reveal">{copy.hero.eyebrow}</p>
				<h1 class="reveal" style="--reveal-delay: 80ms;">
					{copy.hero.headlineLine1}<br /><span class="serif-italic">{copy.hero.headlineAccent}</span>
				</h1>
				<p class="hero-sub reveal" style="--reveal-delay: 160ms;">
					{copy.hero.sub}
				</p>
				<div class="hero-ctas reveal" style="--reveal-delay: 240ms;">
					<a href="/program" class="btn btn-primary">{copy.hero.ctaPrimary}</a>
					<a href="/hubungi?intent=proposal" class="btn btn-outline">{copy.hero.ctaSecondary}</a>
				</div>
				<dl class="hero-stats reveal" style="--reveal-delay: 320ms;">
					{copy.hero.stats.map((s) => (
						<div>
							<dt>{s.label}</dt>
							<dd>{s.value}</dd>
						</div>
					))}
				</dl>
			</div>
			<aside class="hero-aside reveal" style="--reveal-delay: 180ms;">
				<Image
					src={heroTraining}
					alt={copy.hero.imageAlt}
					class="hero-image"
					loading="eager"
					widths={[400, 600, 900, 1200]}
					sizes="(max-width: 880px) 100vw, 600px"
				/>
				<div class="hero-badge">
					<p class="badge-label">{copy.hero.badgeLabel}</p>
					<p class="badge-value">{copy.hero.badgeValue} <span>{copy.hero.badgeUnit}</span></p>
				</div>
			</aside>
		</div>
	</section>

	{/* ---------- 2. TRUST INDICATORS ---------- */}
	<section class="trust section-ash" aria-label="Klien dan rakan kongsi">
		<div class="container">
			<p class="trust-label reveal">{copy.trustLabel}</p>
			<ul class="trust-logos">
				{TRUSTED_BY.map((name, i) => (
					<li class="trust-logo reveal" style={`--reveal-delay: ${i * 60}ms;`} aria-label={name}>
						<span>{name}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	{/* ---------- 3. CORE TRAINING ECOSYSTEM ---------- */}
	<section id="modul" class="modules section-paper">
		<div class="container">
			<header class="section-head reveal">
				<p class="eyebrow">{copy.programs.eyebrow}</p>
				<h2>{copy.programs.heading}</h2>
				<p class="section-lede">
					{copy.programs.lede}
				</p>
			</header>

			<ol class="program-cards">
				{moduleEntries.map(([key, mod], i) => (
					<li class="program-card reveal" style={`--reveal-delay: ${(i % 3) * 80}ms;`}>
						<span class="program-num">{String(i + 1).padStart(2, '0')}</span>
						<h3 id={`modul-${key}`}>{mod.label}</h3>
						<p class="program-desc">{mod.description}</p>
						<p class="program-hasil"><span>Hasil</span>{mod.hasil}</p>
						<a href={`/program/${key}`} class="program-cta">{copy.programs.cardCta}</a>
					</li>
				))}
			</ol>
		</div>
	</section>

	{/* ---------- 4. METHODOLOGY ---------- */}
	<section id="metodologi" class="methodology section-navy">
		<div class="container">
			<header class="section-head reveal">
				<p class="eyebrow eyebrow-light">{copy.methodology.eyebrow}</p>
				<h2>{copy.methodology.heading}</h2>
				<p class="section-lede on-dark">
					{copy.methodology.lede}
				</p>
			</header>

			<ol class="method-grid">
				{METHODOLOGY.map((step, i) => (
					<li class="method-card reveal" style={`--reveal-delay: ${i * 120}ms;`}>
						<span class="method-num">{step.num}</span>
						<h3>{step.title} <span class="method-bm">{step.bm}</span></h3>
						<p>{step.desc}</p>
					</li>
				))}
			</ol>

			<div class="method-flow" aria-hidden="true">
				{copy.methodology.flow.map((step, i) => (
					<>
						<span class={`flow-step${i === copy.methodology.flow.length - 1 ? ' flow-step-gold' : ''}`}>{step}</span>
						{i < copy.methodology.flow.length - 1 && <span class="flow-arrow">→</span>}
					</>
				))}
			</div>
		</div>
	</section>

	{/* ---------- 5. ENTERPRISE PUBLISHING ---------- */}
	<section class="enterprise section-paper">
		<div class="container enterprise-grid">
			<div class="enterprise-copy reveal">
				<p class="eyebrow">{copy.enterprise.eyebrow}</p>
				<h2>{copy.enterprise.heading}</h2>
				<p>
					{copy.enterprise.body}
				</p>
				<ul class="enterprise-list">
					{copy.enterprise.list.map((item) => <li>{item}</li>)}
				</ul>
				<a href="/penerbitan" class="btn btn-outline">{copy.enterprise.cta}</a>
			</div>
			<aside class="enterprise-aside reveal" style="--reveal-delay: 120ms;">
				<Image
					src={enterprisePublishing}
					alt={copy.enterprise.imageAlt}
					class="enterprise-image"
					loading="lazy"
					widths={[400, 600, 688]}
					sizes="(max-width: 880px) 100vw, 600px"
				/>
			</aside>
		</div>
	</section>

	{/* ---------- 6. LEGACY & EXECUTION (2x2 grid) ---------- */}
	<section class="legacy-services section-ash">
		<div class="container">
			<header class="section-head reveal">
				<p class="eyebrow">{copy.legacy.eyebrow}</p>
				<h2>{copy.legacy.heading}</h2>
				<p class="section-lede">
					{copy.legacy.lede}
				</p>
			</header>

			<ol class="legacy-grid">
				{legacyServices.map((s, i) => (
					<li class="legacy-card reveal" style={`--reveal-delay: ${i * 90}ms;`}>
						<div class="legacy-icon" aria-hidden="true">
							<svg
								class="legacy-svg"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								set:html={ICON_PATHS[s.icon]}
							/>
						</div>
						<span class="legacy-num" aria-hidden="true">{s.num}</span>
						<h3>{s.title}</h3>
						<p>{s.desc}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	{/* ---------- 7. CASE STUDIES ---------- */}
	<section id="kajian-kes" class="case-studies section-paper">
		<div class="container">
			<header class="section-head reveal">
				<p class="eyebrow">{copy.cases.eyebrow}</p>
				<h2>{copy.cases.heading}</h2>
				<p class="section-lede">
					{copy.cases.lede}
				</p>
			</header>

			<ol class="case-grid">
				{CASE_STUDIES.map((cs, i) => (
					<li class="case-card reveal" style={`--reveal-delay: ${i * 100}ms;`}>
						<p class="case-metric">{cs.metric}</p>
						<p class="case-metric-label">{cs.label}</p>
						<blockquote>
							<p>{cs.quote}</p>
						</blockquote>
						<cite>— {cs.attribution}</cite>
					</li>
				))}
			</ol>
		</div>
	</section>

	{/* ---------- 7. LEAD GEN ---------- */}
	<section id="intake" class="lead-gen section-paper">
		<div class="container-narrow lead-grid">
			<header class="reveal">
				<p class="eyebrow">{copy.leadgen.eyebrow}</p>
				<h2>{copy.leadgen.heading}</h2>
				<p>
					{copy.leadgen.body}
				</p>
				<ul class="trust-list">
					{copy.leadgen.points.map((p) => <li>{p}</li>)}
				</ul>
			</header>

			<form class="lead-form reveal" style="--reveal-delay: 120ms;" method="post" action="#">
				<div class="row-2">
					<div class="field">
						<label for="lf-name">{copy.leadgen.labelName}</label>
						<input id="lf-name" name="name" type="text" required autocomplete="name" />
					</div>
					<div class="field">
						<label for="lf-email">{copy.leadgen.labelEmail}</label>
						<input id="lf-email" name="email" type="email" required autocomplete="email" />
					</div>
				</div>

				<div class="row-2">
					<div class="field">
						<label for="lf-org">{copy.leadgen.labelOrg}</label>
						<input id="lf-org" name="organization" type="text" required autocomplete="organization" />
					</div>
					<div class="field">
						<label for="lf-position">{copy.leadgen.labelPosition}</label>
						<input id="lf-position" name="position" type="text" autocomplete="organization-title" />
					</div>
				</div>

				<div class="row-2">
					<div class="field">
						<label for="lf-pax">{copy.leadgen.labelPax}</label>
						<select id="lf-pax" name="pax" required>
							<option value="">Pilih…</option>
							{PAX_OPTIONS.map((opt) => <option value={opt.value}>{opt.label}</option>)}
						</select>
					</div>
					<div class="field">
						<label for="lf-program">{copy.leadgen.labelProgram}</label>
						<select id="lf-program" name="program" required>
							<option value="">Pilih…</option>
							{PROGRAM_OPTIONS.map((opt) => <option value={opt.value}>{opt.label}</option>)}
						</select>
					</div>
				</div>

				<div class="field">
					<label for="lf-message">{copy.leadgen.labelMessage}</label>
					<textarea id="lf-message" name="message" rows="4" placeholder={copy.leadgen.messagePlaceholder}></textarea>
				</div>

				<button type="submit" class="btn btn-primary lead-submit">{copy.leadgen.submit}</button>
				<p class="form-note">{copy.leadgen.note}</p>
			</form>
		</div>
	</section>
</BaseLayout>

<style>
	/* ---------- HERO ---------- */
	.hero { padding-block: clamp(4rem, 8vw, 7rem); }
	.hero-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (max-width: 980px) {
		.hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
		.hero-aside { display: none; }
	}

	.hero-copy h1 {
		margin-top: 1.5rem;
		font-size: clamp(1.875rem, 3.6vw, 3.25rem);
		line-height: 1.1;
	}
	.hero-copy h1 .serif-italic {
		color: var(--gold-700);
	}
	.hero-sub {
		max-width: 56ch;
		margin: 2rem 0 2.5rem;
		font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
		line-height: 1.55;
		color: var(--ink-500);
	}
	.hero-ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 3rem;
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(3, auto);
		gap: 2.5rem;
		margin: 0;
		padding-top: 2rem;
		border-top: 1px solid var(--ash-200);
		justify-content: start;
	}
	.hero-stats div { display: flex; flex-direction: column; gap: 0.25rem; }
	.hero-stats dt {
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
	}
	.hero-stats dd {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.75rem;
		color: var(--ink-900);
		margin: 0;
	}

	.hero-aside {
		position: relative;
	}
	.hero-image {
		width: 100%;
		height: auto;
		max-height: 560px;
		object-fit: cover;
		border-radius: var(--radius);
		box-shadow: var(--shadow);
	}
	.hero-badge {
		position: absolute;
		left: -1.5rem;
		bottom: 1.5rem;
		background: var(--paper);
		padding: 1.25rem 1.5rem;
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		border-left: 4px solid var(--gold-600);
	}
	.badge-label {
		margin: 0;
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
	}
	.badge-value {
		margin: 0.5rem 0 0;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 2rem;
		color: var(--ink-900);
	}
	.badge-value span {
		font-family: var(--font-body);
		font-weight: 400;
		font-size: var(--text-sm);
		color: var(--ink-500);
	}

	/* ---------- TRUST ---------- */
	.trust { padding-block: 3rem; }
	.trust-label {
		text-align: center;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
		margin: 0 0 2rem;
	}
	.trust-logos {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.5rem;
		align-items: center;
	}
	@media (max-width: 880px) { .trust-logos { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 540px) { .trust-logos { grid-template-columns: repeat(2, 1fr); } }
	.trust-logo {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.125rem;
		text-align: center;
		color: var(--ink-300);
		padding: 1rem;
		border: 1px dashed var(--ash-300);
		border-radius: var(--radius);
		filter: grayscale(1);
		transition: color var(--transition-fast), border-color var(--transition-fast);
	}
	.trust-logo:hover { color: var(--ink-500); border-color: var(--ash-300); }

	/* ---------- SECTION HEADERS ---------- */
	.section-head {
		max-width: 820px;
		margin-bottom: 4rem;
	}
	.section-head h2 {
		margin-top: 1rem;
		font-size: clamp(2.25rem, 4vw, 3.25rem);
	}
	.section-lede {
		margin-top: 1.5rem;
		font-size: var(--text-lg);
		line-height: 1.55;
		color: var(--ink-500);
		max-width: 64ch;
	}
	.section-lede.on-dark { color: var(--ink-on-dark); }
	.eyebrow-light { color: var(--gold-300); }

	/* ---------- PROGRAMS (6-card grid) ---------- */
	.program-cards {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	@media (max-width: 920px) { .program-cards { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 600px) { .program-cards { grid-template-columns: 1fr; } }
	.program-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 2.25rem 2rem;
		background: var(--ash-50);
		border: 1px solid var(--ash-200);
		border-top: 4px solid var(--gold-600);
		border-radius: var(--radius);
		transition: transform var(--transition-fast), box-shadow var(--transition);
	}
	.program-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
	.program-num {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.75rem;
		line-height: 1;
		color: var(--gold-500);
		opacity: 0.6;
		margin-bottom: 1rem;
	}
	.program-card h3 {
		font-size: var(--text-xl);
		line-height: 1.2;
		margin: 0 0 0.85rem;
		min-height: 2.4em;
	}
	.program-desc {
		font-size: var(--text-base);
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0 0 1.5rem;
		flex-grow: 1;
	}
	.program-hasil {
		font-size: var(--text-sm);
		line-height: 1.5;
		color: var(--ink-900);
		margin: 0 0 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--ash-200);
	}
	.program-hasil span {
		display: block;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-700);
		margin-bottom: 0.4rem;
	}
	.program-cta {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--navy-800);
		text-decoration: none;
		transition: color var(--transition-fast);
	}
	.program-cta:hover { color: var(--gold-700); }

	/* ---------- METHODOLOGY ---------- */
	.method-grid {
		list-style: none;
		padding: 0;
		margin: 0 0 4rem;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}
	@media (max-width: 880px) { .method-grid { grid-template-columns: 1fr; } }
	.method-card {
		padding: 2.5rem 2rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: var(--radius);
		transition: border-color var(--transition-fast), background var(--transition-fast);
	}
	.method-card:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: var(--gold-500);
	}
	.method-num {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 3.5rem;
		line-height: 1;
		color: var(--gold-300);
		display: block;
		margin-bottom: 1.25rem;
	}
	.method-card h3 {
		font-size: var(--text-2xl);
		margin: 0 0 1rem;
		color: var(--ink-on-dark-strong);
	}
	.method-bm {
		font-family: var(--font-body);
		font-weight: 400;
		font-size: var(--text-sm);
		color: var(--gold-300);
		letter-spacing: var(--tracking-wide);
	}
	.method-card p {
		margin: 0;
		color: var(--ink-on-dark);
		line-height: 1.6;
	}

	.method-flow {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px dashed rgba(255, 255, 255, 0.2);
		border-radius: var(--radius);
	}
	.flow-step {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-on-dark);
	}
	.flow-step-gold { color: var(--gold-300); }
	.flow-arrow {
		color: var(--ink-on-dark-muted);
		font-size: 1.5rem;
	}

	/* ---------- ENTERPRISE ---------- */
	.enterprise-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (max-width: 880px) { .enterprise-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
	.enterprise-copy h2 { margin-top: 1.25rem; }
	.enterprise-copy p {
		margin: 1.5rem 0 1.5rem;
		font-size: var(--text-lg);
		line-height: 1.6;
		max-width: 56ch;
	}
	.enterprise-list {
		list-style: none;
		padding: 0;
		margin: 0 0 2.5rem;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5rem 1.5rem;
	}
	@media (max-width: 560px) { .enterprise-list { grid-template-columns: 1fr; } }
	.enterprise-list li {
		position: relative;
		padding-left: 1.25rem;
		font-size: var(--text-base);
		color: var(--ink-700);
	}
	.enterprise-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.7em;
		width: 8px;
		height: 1px;
		background: var(--gold-600);
	}
	.enterprise-image {
		width: 100%;
		height: auto;
		max-height: 520px;
		object-fit: cover;
		border-radius: var(--radius);
		box-shadow: var(--shadow);
	}

	/* ---------- LEGACY & EXECUTION (2x2 grid) ---------- */
	.legacy-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
