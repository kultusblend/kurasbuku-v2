---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MODULES, SITE_ORG, type ModuleKey } from '../consts';

const moduleEntries = Object.entries(MODULES) as [ModuleKey, (typeof MODULES)[ModuleKey]][];

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Course schema per program — eligible for Google course rich results.
const courseSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: moduleEntries.map(([key, mod], i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'Course',
			name: mod.label,
			description: mod.description,
			url: `${siteBase}/program#${key}`,
			inLanguage: 'ms-MY',
			provider: {
				'@type': 'Organization',
				name: SITE_ORG,
				sameAs: siteBase,
			},
			hasCourseInstance: {
				'@type': 'CourseInstance',
				courseMode: ['onsite', 'blended'],
			},
		},
	})),
};
---

<BaseLayout
	title="Program Latihan Komunikasi & Penyampaian"
	description="Enam program latihan Kuras Buku: persona media sosial, pempengaruh buku, resensi buku, cakap depan kamera, moderator interaktif, dan keyakinan pentas."
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
	</Fragment>

	{/* ---------- HERO ---------- */}
	<section class="page-hero section-paper">
		<div class="container">
			<p class="eyebrow reveal">Program Latihan</p>
			<h1 class="reveal" style="--reveal-delay: 80ms;">
				Enam Program,<br /><span class="serif-italic">Satu Suara yang Yakin.</span>
			</h1>
			<p class="page-lede reveal" style="--reveal-delay: 160ms;">
				Setiap program dirangka untuk membina keyakinan dan keupayaan menyampaikan idea, sama ada di skrin, di kertas, mahupun di pentas. Ambil satu mengikut keperluan, atau gabungkan untuk transformasi penuh.
			</p>
			<ul class="hero-tags reveal" style="--reveal-delay: 240ms;">
				<li>Boleh disesuaikan mengikut keperluan</li>
				<li>Bengkel praktikal, bukan kuliah</li>
				<li>On-site atau hybrid</li>
			</ul>
		</div>
	</section>

	{/* ---------- PROGRAM CATALOG ---------- */}
	<section class="catalog section-ash">
		<div class="container">
			<ol class="catalog-grid">
				{moduleEntries.map(([key, mod], i) => (
					<li id={key} class="catalog-card reveal" style={`--reveal-delay: ${(i % 3) * 80}ms;`}>
						<span class="catalog-num">{String(i + 1).padStart(2, '0')}</span>
						<h2>{mod.label}</h2>
						<p class="catalog-desc">{mod.description}</p>
						<div class="catalog-hasil">
							<p class="hasil-label">Hasil</p>
							<p class="hasil-text">{mod.hasil}</p>
						</div>
						<a href={`/hubungi?program=${key}`} class="catalog-cta">Mohon program ini →</a>
					</li>
				))}
			</ol>
		</div>
	</section>

	{/* ---------- CTA ---------- */}
	<section class="cta-band section-navy">
		<div class="container-narrow cta-inner reveal">
			<h2>Tidak pasti program yang sesuai untuk pasukan anda?</h2>
			<p>
				Mulakan dengan sesi perbincangan ringkas. Kami bantu kenal pasti keperluan anda dan cadangkan kombinasi program yang paling berkesan.
			</p>
			<div class="cta-row">
				<a href="/hubungi?intent=proposal" class="btn btn-gold">Mohon Cadangan</a>
				<a href="/metodologi" class="btn btn-ghost">Lihat Metodologi Kami</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-hero { padding-block: clamp(5rem, 9vw, 8rem) clamp(3rem, 6vw, 5rem); }
	.page-hero h1 {
		margin-top: 1.5rem;
		font-size: clamp(2.5rem, 5.5vw, 4.75rem);
		line-height: 1.05;
		max-width: 16ch;
	}
	.page-hero h1 .serif-italic { color: var(--gold-700); }
	.page-lede {
		margin-top: 2rem;
		max-width: 62ch;
		font-size: clamp(1.125rem, 1.5vw, 1.375rem);
		line-height: 1.55;
		color: var(--ink-500);
	}
	.hero-tags {
		list-style: none;
		padding: 0;
		margin: 2.5rem 0 0;
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.hero-tags li {
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--navy-800);
		padding: 0.55rem 1.1rem;
		background: var(--navy-50);
		border-radius: var(--radius-pill);
	}

	/* ---------- CATALOG ---------- */
	.catalog { padding-block: clamp(4rem, 7vw, 6.5rem); }
	.catalog-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.75rem;
	}
	@media (max-width: 920px) { .catalog-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 600px) { .catalog-grid { grid-template-columns: 1fr; } }

	.catalog-card {
		display: flex;
		flex-direction: column;
		padding: 2.5rem 2rem;
		background: var(--paper);
		border: 1px solid var(--ash-200);
		border-top: 4px solid var(--gold-600);
		border-radius: var(--radius);
		scroll-margin-top: 100px;
		transition: transform var(--transition-fast), box-shadow var(--transition);
	}
	.catalog-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
	.catalog-num {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 2rem;
		line-height: 1;
		color: var(--gold-500);
		opacity: 0.6;
		margin-bottom: 1rem;
	}
	.catalog-card h2 {
		font-size: var(--text-xl);
		line-height: 1.2;
		margin: 0 0 1rem;
		min-height: 2.4em;
	}
	.catalog-desc {
		font-size: var(--text-base);
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0 0 1.75rem;
		flex-grow: 1;
	}
	.catalog-hasil {
		padding-top: 1.25rem;
		border-top: 1px solid var(--ash-200);
		margin-bottom: 1.5rem;
	}
	.hasil-label {
		margin: 0 0 0.4rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-700);
	}
	.hasil-text { margin: 0; font-size: var(--text-sm); line-height: 1.5; color: var(--ink-900); }
	.catalog-cta {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--navy-800);
		text-decoration: none;
		transition: color var(--transition-fast);
	}
	.catalog-cta:hover { color: var(--gold-700); }

	/* ---------- CTA ---------- */
	.cta-band { padding-block: clamp(4rem, 7vw, 6rem); }
	.cta-inner { text-align: center; }
	.cta-inner h2 { font-size: clamp(1.85rem, 3.5vw, 2.85rem); color: var(--ink-on-dark-strong); max-width: 24ch; margin-inline: auto; }
	.cta-inner p {
		max-width: 56ch;
		margin: 1.5rem auto 2.5rem;
		font-size: var(--text-lg);
		line-height: 1.55;
		color: var(--ink-on-dark);
	}
	.cta-row { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
</style>
