---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MODULES, SITE_ORG, type ModuleKey } from '../consts';

const moduleEntries = Object.entries(MODULES) as [ModuleKey, (typeof MODULES)[ModuleKey]][];

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Course schema per module — eligible for Google course rich results.
const courseSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: moduleEntries.map(([key, mod], i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'Course',
			name: mod.label,
			description: mod.positioning,
			url: `${siteBase}/program#${key}`,
			inLanguage: 'ms-MY',
			provider: {
				'@type': 'Organization',
				name: SITE_ORG,
				sameAs: siteBase,
			},
			hasCourseInstance: {
				'@type': 'CourseInstance',
				courseMode: ['onsite', 'blended'],
				courseWorkload: 'P4W',
			},
		},
	})),
};

// Audience + format per module. SAHKAN butiran sebenar (jumlah sesi, mod) dengan klien.
const moduleMeta: Record<ModuleKey, { audience: string; format: string; tempoh: string }> = {
	penulisan: {
		audience: 'Pegawai dasar, penyelidik, penulis laporan, dan unit komunikasi.',
		format: 'Fizikal atau hybrid, bengkel praktikal',
		tempoh: '8 sesi',
	},
	penerbitan: {
		audience: 'Unit penerbitan, editor dalaman, dan pasukan komunikasi korporat.',
		format: 'Bengkel hands-on dengan tugasan sebenar',
		tempoh: '6 sesi',
	},
	strategik: {
		audience: 'Pegawai perhubungan awam, jurucakap, dan kepimpinan organisasi.',
		format: 'Intensif, dengan sesi konsultasi susulan',
		tempoh: '4 sesi',
	},
};
---

<BaseLayout
	title="Program Latihan Komunikasi Korporat & Kerajaan"
	description="Tiga modul latihan komunikasi korporat: Penulisan Profesional & Dokumentasi, Strategi Penerbitan Korporat, dan Komunikasi Strategik. Direka khas untuk pasukan agensi kerajaan dan organisasi."
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
	</Fragment>

	{/* ---------- HERO ---------- */}
	<section class="page-hero section-paper">
		<div class="container">
			<p class="eyebrow reveal">Program Latihan</p>
			<h1 class="reveal" style="--reveal-delay: 80ms;">
				Tiga Modul Teras,<br /><span class="serif-italic">Satu Pasukan yang Fasih.</span>
			</h1>
			<p class="page-lede reveal" style="--reveal-delay: 160ms;">
				Setiap modul dirangka untuk membina keupayaan dalaman yang kekal. Ambil satu modul mengikut keperluan semasa, atau gabungkan ketiga-tiganya untuk transformasi komunikasi organisasi yang menyeluruh.
			</p>
			<ul class="hero-tags reveal" style="--reveal-delay: 240ms;">
				<li>Kompatibel dengan klaim HRD Corp</li>
				<li>Boleh disesuaikan mengikut konteks organisasi</li>
				<li>On-site atau hybrid</li>
			</ul>
		</div>
	</section>

	{/* ---------- MODULE DETAILS ---------- */}
	{moduleEntries.map(([key, mod], i) => (
		<section id={key} class={`module-detail ${i % 2 === 0 ? 'section-ash' : 'section-paper'}`}>
			<div class="container module-detail-grid">
				<div class="module-intro reveal">
					<span class="module-index">{String(i + 1).padStart(2, '0')}</span>
					<h2>{mod.label}</h2>
					<p class="module-positioning">{mod.positioning}</p>

					<dl class="module-facts">
						<div>
							<dt>Untuk siapa</dt>
							<dd>{moduleMeta[key].audience}</dd>
						</div>
						<div>
							<dt>Tempoh</dt>
							<dd>{moduleMeta[key].tempoh}</dd>
						</div>
						<div>
							<dt>Format</dt>
							<dd>{moduleMeta[key].format}</dd>
						</div>
					</dl>
				</div>

				<div class="module-detail-side reveal" style="--reveal-delay: 120ms;">
					<div class="outcome-card">
						<p class="outcome-label">Hasil yang anda bawa pulang</p>
						<p class="outcome-text">{mod.outcome}</p>
					</div>

					<div class="components">
						<p class="components-label">Komponen Modul</p>
						<ul>
							{mod.bullets.map((b) => <li>{b}</li>)}
						</ul>
					</div>

					<a href="/hubungi?intent=proposal" class="btn btn-primary module-cta">Mohon cadangan untuk modul ini</a>
				</div>
			</div>
		</section>
	))}

	{/* ---------- CTA ---------- */}
	<section class="cta-band section-navy">
		<div class="container-narrow cta-inner reveal">
			<h2>Tidak pasti modul yang sesuai untuk pasukan anda?</h2>
			<p>
				Mulakan dengan sesi diagnostik ringkas. Kami bantu kenal pasti kelompangan komunikasi organisasi anda dan cadangkan kombinasi modul yang paling berkesan.
			</p>
			<div class="cta-row">
				<a href="/hubungi?intent=proposal" class="btn btn-gold">Mohon Cadangan Korporat</a>
				<a href="/metodologi" class="btn btn-ghost">Lihat Metodologi Kami</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-hero { padding-block: clamp(5rem, 9vw, 8rem) clamp(3rem, 6vw, 5rem); }
	.page-hero h1 {
		margin-top: 1.5rem;
		font-size: clamp(2.5rem, 5.5vw, 4.75rem);
		line-height: 1.05;
		max-width: 16ch;
	}
	.page-hero h1 .serif-italic { color: var(--gold-700); }
	.page-lede {
		margin-top: 2rem;
		max-width: 62ch;
		font-size: clamp(1.125rem, 1.5vw, 1.375rem);
		line-height: 1.55;
		color: var(--ink-500);
	}
	.hero-tags {
		list-style: none;
		padding: 0;
		margin: 2.5rem 0 0;
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.hero-tags li {
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--navy-800);
		padding: 0.55rem 1.1rem;
		background: var(--navy-50);
		border-radius: var(--radius-pill);
	}

	/* ---------- MODULE DETAIL ---------- */
	.module-detail { padding-block: clamp(4rem, 7vw, 6.5rem); }
	.module-detail-grid {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 4rem;
		align-items: start;
	}
	@media (max-width: 920px) { .module-detail-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

	.module-index {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 3rem;
		line-height: 1;
		color: var(--gold-500);
		opacity: 0.55;
		display: block;
		margin-bottom: 1rem;
	}
	.module-intro h2 { font-size: clamp(2rem, 3.5vw, 2.85rem); line-height: 1.1; }
	.module-positioning {
		margin: 1.5rem 0 2.5rem;
		font-size: var(--text-lg);
		line-height: 1.6;
		color: var(--ink-700);
		max-width: 50ch;
	}
	.module-facts { margin: 0; display: grid; gap: 1.25rem; }
	.module-facts div {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 1rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--ash-200);
	}
	.module-facts dt {
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
		margin: 0;
	}
	.module-facts dd { margin: 0; font-size: var(--text-sm); color: var(--ink-900); line-height: 1.5; }

	.module-detail-side { display: flex; flex-direction: column; gap: 2rem; }
	.outcome-card {
		padding: 2rem;
		background: var(--navy-900);
		border-radius: var(--radius);
		border-left: 4px solid var(--gold-500);
	}
	.outcome-label {
		margin: 0 0 0.75rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-300);
	}
	.outcome-text {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--text-xl);
		line-height: 1.3;
		color: var(--ink-on-dark-strong);
	}
	.components-label {
		margin: 0 0 1rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
	}
	.components ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.65rem;
	}
	.components li {
		position: relative;
		padding-left: 1.5rem;
		font-size: var(--text-base);
		color: var(--ink-700);
		line-height: 1.5;
	}
	.components li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.65em;
		width: 9px;
		height: 1px;
		background: var(--gold-600);
	}
	.module-cta { align-self: flex-start; }

	/* ---------- CTA ---------- */
	.cta-band { padding-block: clamp(4rem, 7vw, 6rem); }
	.cta-inner { text-align: center; }
	.cta-inner h2 { font-size: clamp(1.85rem, 3.5vw, 2.85rem); color: var(--ink-on-dark-strong); max-width: 22ch; margin-inline: auto; }
	.cta-inner p {
		max-width: 56ch;
		margin: 1.5rem auto 2.5rem;
		font-size: var(--text-lg);
		line-height: 1.55;
		color: var(--ink-on-dark);
	}
	.cta-row { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
</style>
