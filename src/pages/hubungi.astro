---
import BaseLayout from '../layouts/BaseLayout.astro';
import copy from '../content/data/pages/hubungi.json';
import { TRAINING_OPTIONS, PUBLISHING_OPTIONS, PAX_OPTIONS, SSM_REGISTRATION, BUSINESS_ADDRESS, WEB3FORMS_KEY, WEB3FORMS_ACTION } from '../consts';
---

<BaseLayout title={copy.metaTitle} description="Hantar permohonan untuk cadangan latihan korporat atau penerbitan enterprise. Pasukan kami akan respons dalam tempoh 2 hari bekerja.">
	<section class="hubungi-page section-paper">
		<div class="container-narrow">
			<header class="page-head reveal">
				<p class="eyebrow">{copy.heroEyebrow}</p>
				<h1>{copy.heroHeading}</h1>
				<p class="lede">
					{copy.heroSub}
				</p>
			</header>

			<div class="hubungi-grid">
				<form class="hubungi-form reveal" style="--reveal-delay: 80ms;" method="POST" action={WEB3FORMS_KEY ? WEB3FORMS_ACTION : '#'}>
					{WEB3FORMS_KEY && (
						<>
							<input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
							<input type="hidden" name="subject" value="Pertanyaan Baharu (kurasbuku.com)" />
							<input type="hidden" name="from_name" value="Borang Hubungi Kuras Buku" />
							<input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
						</>
					)}
					<fieldset class="form-section">
						<legend>Maklumat anda</legend>
						<div class="row-2">
							<div class="field">
								<label for="hf-name">Nama penuh</label>
								<input id="hf-name" name="name" type="text" required autocomplete="name" />
							</div>
							<div class="field">
								<label for="hf-position">Jawatan</label>
								<input id="hf-position" name="position" type="text" autocomplete="organization-title" />
							</div>
						</div>
						<div class="row-2">
							<div class="field">
								<label for="hf-email">E-mel kerja</label>
								<input id="hf-email" name="email" type="email" required autocomplete="email" />
							</div>
							<div class="field">
								<label for="hf-phone">No. telefon</label>
								<input id="hf-phone" name="phone" type="tel" autocomplete="tel" />
							</div>
						</div>
					</fieldset>

					<fieldset class="form-section">
						<legend>Maklumat organisasi</legend>
						<div class="field">
							<label for="hf-org">Nama organisasi / agensi</label>
							<input id="hf-org" name="organization" type="text" required autocomplete="organization" />
						</div>
						<div class="field">
							<label for="hf-sector">Sektor</label>
							<select id="hf-sector" name="sector">
								<option value="">Pilih…</option>
								<option value="kerajaan">Kerajaan Persekutuan</option>
								<option value="kerajaan-negeri">Kerajaan Negeri</option>
								<option value="glc">GLC / Statutory Body</option>
								<option value="korporat">Korporat Swasta</option>
								<option value="universiti">Universiti / Pendidikan</option>
								<option value="ngo">NGO / Pertubuhan</option>
								<option value="individu">Individu</option>
							</select>
						</div>
					</fieldset>

					<fieldset class="form-section">
						<legend>Apa yang anda perlukan?</legend>
						<div class="field">
							<label for="hf-type">Jenis perkhidmatan</label>
							<select id="hf-type" name="jenis_perkhidmatan" required>
								<option value="">Pilih…</option>
								<option value="penerbitan">Servis Penerbitan</option>
								<option value="latihan">Program Latihan</option>
							</select>
						</div>
					</fieldset>

					<fieldset class="form-section conditional" data-group="penerbitan" hidden disabled>
						<legend>Maklumat penerbitan</legend>
						<div class="field">
							<label for="hf-pubtype">Jenis penerbitan</label>
							<select id="hf-pubtype" name="jenis_penerbitan" required>
								<option value="">Pilih…</option>
								{PUBLISHING_OPTIONS.map((opt) => <option value={opt.value}>{opt.label}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="hf-pubqty">Anggaran kuantiti naskhah (pilihan)</label>
							<input id="hf-pubqty" name="anggaran_kuantiti" type="text" placeholder="Cth: 300 naskhah, atau belum pasti" />
						</div>
					</fieldset>

					<fieldset class="form-section conditional" data-group="latihan" hidden disabled>
						<legend>Maklumat latihan</legend>
						<div class="field">
							<label for="hf-program">Program berminat</label>
							<select id="hf-program" name="program" required>
								<option value="">Pilih…</option>
								{TRAINING_OPTIONS.map((opt) => <option value={opt.value}>{opt.label}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="hf-pax">Anggaran peserta</label>
							<select id="hf-pax" name="pax" required>
								<option value="">Pilih…</option>
								{PAX_OPTIONS.map((opt) => <option value={opt.value}>{opt.label}</option>)}
							</select>
						</div>
					</fieldset>

					<fieldset class="form-section">
						<legend>Jadual & keperluan</legend>
						<div class="field">
							<label for="hf-timeline">Jadual yang dicadangkan (pilihan)</label>
							<input id="hf-timeline" name="timeline" type="text" placeholder="Cth: Q3 2026, atau dalam 6 minggu" />
						</div>
						<div class="field">
							<label for="hf-message">Keperluan khusus atau soalan</label>
							<textarea id="hf-message" name="message" rows="5" placeholder="Ceritakan tentang konteks organisasi, skop projek, atau apa-apa keperluan khas…"></textarea>
						</div>
					</fieldset>

					<button type="submit" class="btn btn-primary form-submit">Hantar Permohonan</button>
					<p class="form-note">Maklumat anda hanya digunakan untuk memproses permohonan ini. Tidak akan dikongsi dengan mana-mana pihak ketiga.</p>
				</form>

				<aside class="contact-aside reveal" style="--reveal-delay: 160ms;">
					<h2>{copy.contactHeading}</h2>
					<dl>
						<div>
							<dt>E-mel rasmi</dt>
							<dd><a href="mailto:proposal@kurasbuku.com">proposal@kurasbuku.com</a></dd>
						</div>
						<div>
							<dt>Tempoh respons</dt>
							<dd>2 hari bekerja</dd>
						</div>
						<div>
							<dt>Waktu operasi</dt>
							<dd>Isnin – Jumaat, 9.00 pagi – 6.00 petang</dd>
						</div>
					</dl>

					<div class="vendor-card">
						<p class="vendor-label">Maklumat Vendor</p>
						<p class="vendor-name">Penerbitan Kuras Buku</p>
						<p class="vendor-detail">{SSM_REGISTRATION}</p>
						<p class="vendor-detail">{BUSINESS_ADDRESS}</p>
					</div>

					<div class="response-card">
						<p class="response-label">Selepas anda hantar borang</p>
						<ol>
							<li>Pasukan menerima permohonan secara automatik</li>
							<li>Diagnostik ringkas keperluan organisasi (15 minit panggilan)</li>
							<li>Proposal khas dengan kos dan jadual dihantar dalam 2 hari</li>
						</ol>
					</div>
				</aside>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	function setupHubungiForm() {
		const form = document.querySelector('.hubungi-form');
		if (!form) return;
		const sel = form.querySelector('#hf-type');
		if (!sel || sel.dataset.bound) return;
		sel.dataset.bound = '1';
		const groups = {
			penerbitan: form.querySelector('[data-group="penerbitan"]'),
			latihan: form.querySelector('[data-group="latihan"]'),
		};
		const subject = form.querySelector('input[name="subject"]');
		const setG = (g, on) => { if (g) { g.hidden = !on; g.disabled = !on; } };
		function apply() {
			const v = sel.value;
			setG(groups.penerbitan, v === 'penerbitan');
			setG(groups.latihan, v === 'latihan');
			if (subject) {
				subject.value =
					v === 'penerbitan' ? 'Pertanyaan Servis Penerbitan (kurasbuku.com)'
						: v === 'latihan' ? 'Pertanyaan Program Latihan (kurasbuku.com)'
							: 'Pertanyaan Baharu (kurasbuku.com)';
			}
		}
		sel.addEventListener('change', apply);
		const params = new URLSearchParams(location.search);
		const program = params.get('program');
		const intent = params.get('intent');
		if (program) { sel.value = 'latihan'; }
		else if (intent === 'proposal') { sel.value = 'penerbitan'; }
		apply();
		if (program) {
			const ps = form.querySelector('#hf-program');
			if (ps && [...ps.options].some((o) => o.value === program)) ps.value = program;
		}
	}
	document.addEventListener('astro:page-load', setupHubungiForm);
	setupHubungiForm();
</script>

<style>
	.hubungi-page { padding-block: clamp(5rem, 9vw, 8rem); }
	.page-head { max-width: 760px; margin: 0 auto 4rem; text-align: center; }
	.page-head h1 { font-size: clamp(2.5rem, 5vw, 4rem); margin: 1rem 0 1.5rem; line-height: 1.05; }
	.page-head .lede {
		font-size: var(--text-lg);
		line-height: 1.55;
		color: var(--ink-500);
		max-width: 56ch;
		margin: 0 auto;
	}

	.hubungi-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 3.5rem;
		align-items: start;
	}
	@media (max-width: 980px) { .hubungi-grid { grid-template-columns: 1fr; } }

	.hubungi-form {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 2.5rem;
		background: var(--ash-50);
		border-radius: var(--radius);
		border: 1px solid var(--ash-200);
	}
	.form-section {
		border: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	/* Conditional groups: class+attribute specificity beats .form-section's display:flex */
	.conditional[hidden] { display: none; }
	.form-section legend {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--navy-800);
		padding: 0;
		margin-bottom: 0.5rem;
	}
	.row-2 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
	@media (max-width: 540px) { .row-2 { grid-template-columns: 1fr; } }

	.field { display: flex; flex-direction: column; gap: 0.4rem; }
	.field label {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--ink-900);
	}
	.field input,
	.field select,
	.field textarea {
		font-family: var(--font-body);
		font-size: var(--text-base);
		padding: 0.85rem 1rem;
		background: var(--paper);
		border: 1px solid var(--ash-300);
		border-radius: var(--radius);
		color: var(--ink-900);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}
	.field input:focus,
	.field select:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--navy-700);
		box-shadow: 0 0 0 3px rgba(26, 60, 112, 0.1);
	}
	.form-submit { width: fit-content; padding: 1rem 2.5rem; }
	.form-note {
		margin: 0;
		font-size: var(--text-xs);
		color: var(--ink-500);
	}

	.contact-aside h2 {
		font-size: var(--text-2xl);
		margin: 0 0 1.5rem;
	}
	.contact-aside dl {
		margin: 0 0 2.5rem;
		padding: 0;
	}
	.contact-aside dl div {
		padding: 1rem 0;
		border-bottom: 1px solid var(--ash-200);
	}
	.contact-aside dt {
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--ink-500);
		margin: 0 0 0.35rem;
	}
	.contact-aside dd {
		margin: 0;
		font-size: var(--text-base);
		color: var(--ink-900);
	}
	.contact-aside a { color: var(--navy-800); }

	.vendor-card,
	.response-card {
		padding: 1.5rem;
		background: var(--ash-50);
		border-left: 4px solid var(--gold-600);
		border-radius: var(--radius);
		margin-bottom: 1.5rem;
	}
	.vendor-label,
	.response-label {
		margin: 0 0 0.75rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-700);
	}
	.vendor-name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--text-lg);
		color: var(--ink-900);
		margin: 0 0 0.5rem;
	}
	.vendor-detail {
		margin: 0.25rem 0;
		font-size: var(--text-sm);
		color: var(--ink-700);
	}
	.response-card ol {
		margin: 0;
		padding-left: 1.5rem;
		display: grid;
		gap: 0.5rem;
	}
	.response-card li {
		font-size: var(--text-sm);
		color: var(--ink-700);
		line-height: 1.55;
	}
</style>
