---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { ARTICLE_CATEGORIES, ARTICLE_CTA } from '../../consts';

export async function getStaticPaths() {
	// Drafts are built in dev (so they can be previewed) but excluded from
	// production until reviewed + draft:false.
	const posts = await getCollection('blog', ({ data }) =>
		import.meta.env.PROD ? !data.draft : true
	);
	return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, module, tldr } = post.data;

const author = post.data.author ? await getEntry(post.data.author) : null;
const authorName = author?.data.name ?? 'Penerbitan Kuras Buku';

const words = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));

const category = ARTICLE_CATEGORIES[module] ?? 'Umum';
const cta = ARTICLE_CTA[module] ?? ARTICLE_CTA.umum;

const formatter = new Intl.DateTimeFormat('ms-MY', { year: 'numeric', month: 'long', day: 'numeric' });

const all = await getCollection('blog', ({ data }) =>
	import.meta.env.PROD ? !data.draft : true
);
const related = all
	.filter((p) => p.id !== post.id && p.data.module === module)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);
---

<BaseLayout
	title={title}
	description={description}
	article={true}
	pubDate={pubDate}
	updatedDate={updatedDate}
	authorName={authorName}
	tags={tags}
>
	<article class="post section-paper">
		<div class="container-narrow">
			<a href="/artikel" class="back-link reveal">← Semua Artikel</a>
			<p class="eyebrow reveal" style="--reveal-delay: 60ms;">{category}</p>
			<h1 class="reveal" style="--reveal-delay: 120ms;">{title}</h1>
			<p class="post-meta reveal" style="--reveal-delay: 180ms;">
				<span>{authorName}</span>
				<span class="dot" aria-hidden="true">·</span>
				<time datetime={pubDate.toISOString()}>{formatter.format(pubDate)}</time>
				<span class="dot" aria-hidden="true">·</span>
				<span>{readingTime} minit bacaan</span>
			</p>

			{tldr && (
				<aside class="post-tldr reveal" style="--reveal-delay: 220ms;">
					<p class="post-tldr-label">Ringkasan</p>
					<p>{tldr}</p>
				</aside>
			)}

			<div class="article-body reveal" style="--reveal-delay: 260ms;">
				<Content />
			</div>

			{tags.length > 0 && (
				<ul class="post-tags">
					{tags.map((t) => <li>{t}</li>)}
				</ul>
			)}

			<div class="author-card">
				<p class="author-card-label">Ditulis oleh</p>
				<p class="author-card-name">{authorName}</p>
				{author?.data.role && <p class="author-card-role">{author.data.role}</p>}
				{author?.data.bio && <p class="author-card-bio">{author.data.bio}</p>}
			</div>
		</div>
	</article>

	{related.length > 0 && (
		<section class="related section-ash">
			<div class="container">
				<h2 class="related-head reveal">Artikel berkaitan</h2>
				<ol class="related-grid">
					{related.map((p, i) => (
						<li class="related-card reveal" style={`--reveal-delay: ${i * 80}ms;`}>
							<a href={`/artikel/${p.id}/`}>
								<span class="related-cat">{ARTICLE_CATEGORIES[p.data.module] ?? 'Umum'}</span>
								<h3>{p.data.title}</h3>
								<span class="related-cta">Baca →</span>
							</a>
						</li>
					))}
				</ol>
			</div>
		</section>
	)}

	<section class="cta-band section-navy">
		<div class="container-narrow cta-inner reveal">
			<h2>Sedia untuk langkah seterusnya?</h2>
			<p>
				Daripada manuskrip pertama hingga penerbitan korporat, pasukan Penerbitan Kuras Buku
				membantu anda menulis, menerbit, dan menyampaikan idea dengan yakin.
			</p>
			<div class="cta-row">
				<a href={cta.href} class="btn btn-gold">{cta.label}</a>
				<a href="/hubungi" class="btn btn-ghost">Hubungi Kami</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.post { padding-block: clamp(4rem, 8vw, 6.5rem) clamp(3rem, 6vw, 5rem); }
	.back-link {
		display: inline-block;
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--ink-500);
		text-decoration: none;
		margin-bottom: 2rem;
		transition: color var(--transition-fast);
	}
	.back-link:hover { color: var(--gold-700); }
	.post h1 {
		margin: 1rem 0 0;
		font-size: clamp(2.1rem, 4.5vw, 3.4rem);
		line-height: 1.1;
		max-width: 24ch;
	}
	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
		margin: 1.5rem 0 0;
		font-size: var(--text-sm);
		color: var(--ink-500);
	}
	.post-meta .dot { color: var(--ash-300); }

	.post-tldr {
		margin: 2.5rem 0 0;
		padding: 1.5rem 1.75rem;
		background: var(--ash-50);
		border-left: 4px solid var(--gold-600);
		border-radius: var(--radius);
	}
	.post-tldr-label {
		margin: 0 0 0.5rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-700);
	}
	.post-tldr p:last-child { margin: 0; color: var(--ink-700); line-height: 1.6; }

	/* ---------- ARTICLE PROSE ---------- */
	.article-body {
		margin-top: 3rem;
		font-size: var(--text-lg);
		line-height: 1.75;
		color: var(--ink-700);
	}
	.article-body :global(h2) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.6rem, 3vw, 2.1rem);
		line-height: 1.2;
		color: var(--navy-900);
		margin: 3rem 0 1rem;
	}
	.article-body :global(h3) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(1.3rem, 2.2vw, 1.6rem);
		line-height: 1.25;
		color: var(--navy-800);
		margin: 2.25rem 0 0.85rem;
	}
	.article-body :global(p) { margin: 0 0 1.4rem; }
	.article-body :global(ul),
	.article-body :global(ol) { margin: 0 0 1.4rem; padding-left: 1.5rem; display: grid; gap: 0.6rem; }
	.article-body :global(li) { line-height: 1.65; }
	.article-body :global(li::marker) { color: var(--gold-700); }
	.article-body :global(a) {
		color: var(--navy-800);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: var(--gold-500);
	}
	.article-body :global(a:hover) { color: var(--gold-700); }
	.article-body :global(strong) { color: var(--ink-900); font-weight: 700; }
	.article-body :global(blockquote) {
		margin: 2rem 0;
		padding: 0.5rem 0 0.5rem 1.75rem;
		border-left: 4px solid var(--gold-600);
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(1.25rem, 2vw, 1.5rem);
		line-height: 1.5;
		color: var(--navy-800);
	}
	.article-body :global(blockquote p:last-child) { margin: 0; }
	.article-body :global(hr) { margin: 2.5rem 0; border: none; border-top: 1px solid var(--ash-200); }
	.article-body :global(img) { max-width: 100%; height: auto; border-radius: var(--radius); margin: 1.5rem 0; }
	.article-body :global(code) {
		font-size: 0.9em;
		background: var(--ash-100);
		padding: 0.15em 0.4em;
		border-radius: 4px;
	}
	.article-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: var(--text-base); }
	.article-body :global(th),
	.article-body :global(td) { text-align: left; padding: 0.75rem 1rem; border-bottom: 1px solid var(--ash-200); }
	.article-body :global(th) { color: var(--navy-800); font-weight: 600; }

	/* ---------- TAGS ---------- */
	.post-tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		padding: 0;
		margin: 3rem 0 0;
	}
	.post-tags li {
		font-size: var(--text-xs);
		letter-spacing: var(--tracking-wide);
		color: var(--ink-500);
		background: var(--ash-50);
		border: 1px solid var(--ash-200);
		border-radius: 999px;
		padding: 0.4rem 0.9rem;
	}

	/* ---------- AUTHOR ---------- */
	.author-card {
		margin: 3rem 0 0;
		padding: 1.75rem 2rem;
		background: var(--ash-50);
		border: 1px solid var(--ash-200);
		border-radius: var(--radius);
	}
	.author-card-label {
		margin: 0 0 0.5rem;
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--gold-700);
	}
	.author-card-name { margin: 0; font-family: var(--font-display); font-weight: 700; font-size: var(--text-xl); color: var(--ink-900); }
	.author-card-role { margin: 0.25rem 0 0; font-size: var(--text-sm); color: var(--ink-500); }
	.author-card-bio { margin: 0.85rem 0 0; line-height: 1.65; color: var(--ink-700); }

	/* ---------- RELATED ---------- */
	.related { padding-block: clamp(3.5rem, 6vw, 5rem); }
	.related-head { font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 2.5rem; }
	.related-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; }
	@media (max-width: 820px) { .related-grid { grid-template-columns: 1fr; } }
	.related-card a {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		height: 100%;
		text-decoration: none;
		color: inherit;
		padding: 2rem;
		background: var(--paper);
		border: 1px solid var(--ash-200);
		border-radius: var(--radius);
		transition: transform var(--transition-fast), box-shadow var(--transition);
	}
	.related-card a:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
	.related-cat {
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		color: var(--gold-700);
	}
	.related-card h3 { font-size: var(--text-lg); line-height: 1.3; margin: 0; flex: 1; }
	.related-cta { font-size: var(--text-sm); font-weight: 600; color: var(--navy-800); }

	/* ---------- CTA ---------- */
	.cta-band { padding-block: clamp(4rem, 7vw, 6rem); }
	.cta-inner { text-align: center; }
	.cta-inner h2 { font-size: clamp(1.75rem, 3.2vw, 2.6rem); color: var(--ink-on-dark-strong); max-width: 22ch; margin-inline: auto; }
	.cta-inner p {
		max-width: 54ch;
		margin: 1.5rem auto 2.5rem;
		font-size: var(--text-lg);
		line-height: 1.55;
		color: var(--ink-on-dark);
	}
	.cta-row { display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
</style>
