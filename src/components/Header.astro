---
import { SITE_TITLE } from '../consts';

const navItems = [
	{ label: 'Program', href: '/program' },
	{ label: 'Metodologi', href: '/metodologi' },
	{ label: 'Penerbitan', href: '/penerbitan' },
	{ label: 'Kajian Kes', href: '/kajian-kes' },
	{ label: 'Artikel', href: '/artikel' },
	{ label: 'Tentang', href: '/tentang' },
];
---

<a href="#main" class="skip-link">Langkau ke kandungan utama</a>

<header class="site-header">
	<div class="container header-row">
		<a href="/" class="brand" aria-label={`Halaman utama ${SITE_TITLE}`}>
			<img src="/logo.png" alt="" class="brand-logo" width="48" height="41" />
			<span class="brand-name">{SITE_TITLE}</span>
		</a>

		<nav class="primary-nav" aria-label="Navigasi utama">
			<ul>
				{navItems.map(({ label, href }) => (
					<li><a href={href}>{label}</a></li>
				))}
			</ul>
		</nav>

		<a href="/hubungi?intent=proposal" class="btn btn-primary btn-cta-header">
			Mohon Cadangan
		</a>

		<button
			class="nav-toggle"
			aria-controls="mobile-nav"
			aria-expanded="false"
			aria-label="Buka menu navigasi"
			type="button"
		>
			<span></span><span></span><span></span>
		</button>
	</div>

	<nav id="mobile-nav" class="mobile-nav" aria-label="Navigasi mudah alih" hidden>
		<ul>
			{navItems.map(({ label, href }) => (
				<li><a href={href}>{label}</a></li>
			))}
			<li><a href="/hubungi?intent=proposal" class="mobile-cta">Mohon Cadangan</a></li>
		</ul>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: saturate(150%) blur(12px);
		-webkit-backdrop-filter: saturate(150%) blur(12px);
		border-bottom: 1px solid var(--ash-200);
	}

	.header-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		min-height: 76px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ink-900);
	}
	.brand-logo {
		display: block;
		width: auto;
		height: 38px;
	}
	.brand-name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.25rem;
		letter-spacing: var(--tracking-snug);
		white-space: nowrap;
	}
	@media (max-width: 400px) {
		.brand-name { font-size: 1.05rem; }
	}

	.primary-nav ul {
		display: flex;
		gap: 2rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.primary-nav a {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--ink-700);
		text-decoration: none;
		letter-spacing: 0;
		white-space: nowrap;
		position: relative;
		transition: color var(--transition-fast);
	}
	.primary-nav a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		height: 1px;
		width: 0;
		background: var(--gold-600);
		transition: width var(--transition);
	}
	.primary-nav a:hover { color: var(--ink-900); }
	.primary-nav a:hover::after { width: 100%; }

	.btn-cta-header { padding: 0.65rem 1.25rem; font-size: var(--text-sm); }

	.nav-toggle {
		display: none;
		background: transparent;
		border: 1px solid var(--ash-300);
		border-radius: var(--radius-sm);
		padding: 0.5rem;
		width: 44px;
		height: 44px;
		cursor: pointer;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 4px;
	}
	.nav-toggle span {
		display: block;
		width: 22px;
		height: 1.5px;
		background: var(--ink-900);
		transition: transform var(--transition-fast), opacity var(--transition-fast);
	}
	.nav-toggle[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(5.5px) rotate(45deg);
	}
	.nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
	.nav-toggle[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-5.5px) rotate(-45deg);
	}

	.mobile-nav {
		border-top: 1px solid var(--ash-200);
		background: var(--paper);
	}
	.mobile-nav[hidden] { display: none; }
	.mobile-nav ul {
		list-style: none;
		margin: 0;
		padding: 1rem var(--gutter) 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.mobile-nav a {
		display: block;
		padding: 0.75rem 0;
		font-size: var(--text-lg);
		color: var(--ink-900);
		text-decoration: none;
		border-bottom: 1px solid var(--ash-100);
	}
	.mobile-cta {
		margin-top: 0.5rem;
		background: var(--navy-800);
		color: var(--paper) !important;
		text-align: center;
		border-radius: var(--radius);
		border-bottom: none !important;
		padding: 0.95rem !important;
		font-weight: 600;
	}

	@media (max-width: 980px) {
		.primary-nav,
		.btn-cta-header { display: none; }
		.nav-toggle { display: inline-flex; }
	}
</style>

<script>
	const setupNavToggle = () => {
		const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
		const nav = document.querySelector<HTMLElement>('#mobile-nav');
		if (!toggle || !nav) return;
		toggle.addEventListener('click', () => {
			const isOpen = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!isOpen));
			toggle.setAttribute('aria-label', isOpen ? 'Buka menu navigasi' : 'Tutup menu navigasi');
			nav.hidden = isOpen;
		});
	};
	setupNavToggle();
	document.addEventListener('astro:after-swap', setupNavToggle);
</script>
