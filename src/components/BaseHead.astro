---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/700.css';
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE, SITE_LOCALE, SITE_ORG } from '../consts';

const DEFAULT_OG_IMAGE = '/og-default.png';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	article?: boolean;
	pubDate?: Date;
	updatedDate?: Date;
	authorName?: string;
	tags?: string[];
}

const {
	title,
	description,
	image = DEFAULT_OG_IMAGE,
	article = false,
	pubDate,
	updatedDate,
	authorName,
	tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL =
	typeof image === 'string'
		? new URL(image, Astro.url).toString()
		: new URL(image.src, Astro.url).toString();

const headline = title.replace(/\s*\|\s*Kuras Buku$/, '');

const orgSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_ORG,
	alternateName: 'Kuras Buku',
	url: Astro.site?.toString(),
	logo: new URL('/logo.png', Astro.url).toString(),
	areaServed: 'MY',
	knowsAbout: [
		'Corporate communications training',
		'Government policy writing',
		'Editorial publishing',
		'Strategic communications',
	],
};

const articleSchema =
	article && pubDate
		? {
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline,
				description,
				image: imageURL,
				datePublished: pubDate.toISOString(),
				...(updatedDate && { dateModified: updatedDate.toISOString() }),
				...(authorName && { author: { '@type': 'Person', name: authorName } }),
				publisher: {
					'@type': 'Organization',
					name: SITE_ORG,
					url: Astro.site?.toString(),
					logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.url).toString() },
				},
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
				inLanguage: 'ms-MY',
				...(tags.length > 0 && { keywords: tags.join(', ') }),
			}
		: null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0b1d3a" />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<ClientRouter />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={SITE_LOCALE} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
{articleSchema && (
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
