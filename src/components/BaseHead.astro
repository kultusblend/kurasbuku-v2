---
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@fontsource/playfair-display/latin-400.css';
import '@fontsource/playfair-display/latin-400-italic.css';
import '@fontsource/playfair-display/latin-700.css';
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE, SITE_LOCALE, SITE_ORG, SITE_DESCRIPTION, BUSINESS_ADDRESS_PARTS, SSM_NUMBER } from '../consts';

const DEFAULT_OG_IMAGE = '/og-default.png';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	article?: boolean;
	pubDate?: Date;
	updatedDate?: Date;
	authorName?: string;
	tags?: string[];
}

const {
	title,
	description,
	image = DEFAULT_OG_IMAGE,
	article = false,
	pubDate,
	updatedDate,
	authorName,
	tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL =
	typeof image === 'string'
		? new URL(image, Astro.url).toString()
		: new URL(image.src, Astro.url).toString();

// og:image:type must match the actual file (social scrapers care).
const ogExt = (imageURL.split('?')[0].split('.').pop() || '').toLowerCase();
const ogType =
	ogExt === 'jpg' || ogExt === 'jpeg' ? 'image/jpeg' : ogExt === 'webp' ? 'image/webp' : 'image/png';

// Clean page name: first segment before any " | " (strips both the
// "| Program Latihan" middle and the "| Penerbitan Kuras Buku" suffix).
const headline = title.split(/\s*\|\s*/)[0];

// Staging guard: any *.pages.dev host gets noindex so it never competes
// with the production domain. Set SITE_URL=https://kurasbuku.com on the
// Pages project at cutover and this flips off automatically.
const host = Astro.site?.host ?? '';
const isStaging = host.endsWith('.pages.dev') || host === '';

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? '';

const orgSchema = {
	'@context': 'https://schema.org',
	'@type': ['Organization', 'ProfessionalService'],
	'@id': `${siteBase}/#organization`,
	name: SITE_ORG,
	alternateName: 'Kuras Buku',
	url: Astro.site?.toString(),
	logo: new URL('/logo.png', Astro.url).toString(),
	image: new URL('/og-default.png', Astro.url).toString(),
	description: SITE_DESCRIPTION,
	identifier: {
		'@type': 'PropertyValue',
		propertyID: 'SSM',
		value: SSM_NUMBER,
	},
	areaServed: { '@type': 'Country', name: 'Malaysia' },
	address: {
		'@type': 'PostalAddress',
		streetAddress: BUSINESS_ADDRESS_PARTS.streetAddress,
		addressLocality: BUSINESS_ADDRESS_PARTS.addressLocality,
		addressRegion: BUSINESS_ADDRESS_PARTS.addressRegion,
		postalCode: BUSINESS_ADDRESS_PARTS.postalCode,
		addressCountry: BUSINESS_ADDRESS_PARTS.addressCountry,
	},
	knowsAbout: [
		'Corporate communications training',
		'Government policy writing',
		'Editorial publishing',
		'Strategic communications',
		'Annual report production',
	],
	contactPoint: {
		'@type': 'ContactPoint',
		contactType: 'sales',
		availableLanguage: ['ms', 'en'],
		url: `${siteBase}/hubungi`,
	},
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': `${siteBase}/#website`,
	url: Astro.site?.toString(),
	name: SITE_ORG,
	inLanguage: 'ms-MY',
	publisher: { '@id': `${siteBase}/#organization` },
};

// BreadcrumbList: Utama > [intermediate segments] > Current page.
// e.g. /program/kamera -> Utama > Program > Cakap Depan Kamera
const segments = Astro.url.pathname.split('/').filter(Boolean);
const crumbLabel = (seg: string) =>
	seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, ' ');
// Short name for the current-page crumb: drop any ": descriptor" tail.
const crumbName = headline.split(/\s*:\s*/)[0];
const breadcrumbSchema =
	segments.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Utama', item: siteBase + '/' },
					...segments.map((seg, i) => ({
						'@type': 'ListItem',
						position: i + 2,
						name: i === segments.length - 1 ? crumbName : crumbLabel(seg),
						item:
							i === segments.length - 1
								? canonicalURL.toString()
								: `${siteBase}/${segments.slice(0, i + 1).join('/')}/`,
					})),
				],
			}
		: null;

const articleSchema =
	article && pubDate
		? {
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline,
				description,
				image: imageURL,
				datePublished: pubDate.toISOString(),
				...(updatedDate && { dateModified: updatedDate.toISOString() }),
				...(authorName && { author: { '@type': 'Person', name: authorName } }),
				publisher: {
					'@type': 'Organization',
					name: SITE_ORG,
					url: Astro.site?.toString(),
					logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.url).toString() },
				},
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
				inLanguage: 'ms-MY',
				...(tags.length > 0 && { keywords: tags.join(', ') }),
			}
		: null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0b1d3a" />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<ClientRouter />

<link rel="canonical" href={canonicalURL} />
{isStaging && <meta name="robots" content="noindex,nofollow" />}

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:type" content={ogType} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={headline} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={SITE_LOCALE} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{breadcrumbSchema && (
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
{articleSchema && (
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
