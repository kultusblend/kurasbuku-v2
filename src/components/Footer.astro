---
import { SITE_TITLE, SITE_ORG, SSM_REGISTRATION, BUSINESS_ADDRESS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container footer-grid">
		<div class="colophon">
			<a href="/" class="brand-foot">
				<img src="/logo.png" alt="" class="brand-logo" width="48" height="41" />
				<span class="brand-name">{SITE_TITLE}</span>
			</a>
			<p class="org">{SITE_ORG}</p>
			<p class="vendor">
				<strong>Vendor Verification</strong><br />
				{SSM_REGISTRATION}<br />
				{BUSINESS_ADDRESS}
			</p>
		</div>

		<nav aria-label="Program">
			<h4>Program</h4>
			<ul>
				<li><a href="/program#penulisan">Penulisan Profesional</a></li>
				<li><a href="/program#penerbitan">Penerbitan Korporat</a></li>
				<li><a href="/program#strategik">Komunikasi Strategik</a></li>
				<li><a href="/penerbitan">Enterprise Publishing</a></li>
			</ul>
		</nav>

		<nav aria-label="Organisasi">
			<h4>Organisasi</h4>
			<ul>
				<li><a href="/tentang">Tentang Kami</a></li>
				<li><a href="/metodologi">Metodologi</a></li>
				<li><a href="/kajian-kes">Kajian Kes</a></li>
				<li><a href="/artikel">Wawasan & Artikel</a></li>
				<li><a href="/hubungi">Hubungi</a></li>
			</ul>
		</nav>

		<div class="contact">
			<h4>Bermula</h4>
			<p>Untuk pertanyaan tender, RFP, atau cadangan korporat, sila hantar melalui borang rasmi kami.</p>
			<a href="/hubungi?intent=proposal" class="btn btn-gold btn-foot-cta">Mohon Cadangan</a>
			<p class="response-time">Tempoh respons: 2 hari bekerja</p>
		</div>
	</div>

	<div class="container foot-meta">
		<small>© {year} {SITE_ORG}. Hak cipta terpelihara.</small>
		<small><a href="/privasi">Polisi Privasi</a> · <a href="/terma">Terma Perkhidmatan</a></small>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--navy-900);
		color: var(--ink-on-dark);
		padding-block: 5rem 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
		gap: 3rem;
	}
	@media (max-width: 980px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; } }
	@media (max-width: 540px) { .footer-grid { grid-template-columns: 1fr; } }

	.brand-foot {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ink-on-dark-strong);
	}
	.brand-foot .brand-logo {
		display: block;
		width: auto;
		height: 38px;
		filter: brightness(1.05);
	}
	.brand-foot .brand-name {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.5rem;
	}

	.colophon .org {
		margin: 1.25rem 0 0.25rem;
		font-size: var(--text-sm);
		color: var(--ink-on-dark-muted);
	}
	.colophon .vendor {
		margin: 1.5rem 0 0;
		font-size: var(--text-xs);
		line-height: 1.65;
		color: var(--ink-on-dark-muted);
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	.colophon .vendor strong {
		display: block;
		color: var(--ink-on-dark-strong);
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	h4 {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--ink-on-dark-strong);
		margin: 0 0 1.25rem;
	}
	.site-footer ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}
	.site-footer a {
		color: var(--ink-on-dark);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: color var(--transition-fast);
	}
	.site-footer a:hover { color: var(--gold-300); }

	.contact p:not(.response-time) {
		font-size: var(--text-sm);
		color: var(--ink-on-dark);
		margin: 0 0 1.25rem;
		line-height: 1.55;
	}
	.btn-foot-cta { padding: 0.75rem 1.25rem; font-size: var(--text-sm); }
	.response-time {
		margin: 1rem 0 0;
		font-size: var(--text-xs);
		color: var(--ink-on-dark-muted);
		letter-spacing: var(--tracking-wide);
	}

	.foot-meta {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		font-size: var(--text-xs);
		color: var(--ink-on-dark-muted);
	}
	.foot-meta a { color: var(--ink-on-dark-muted); text-decoration: none; }
	.foot-meta a:hover { color: var(--gold-300); }
</style>
